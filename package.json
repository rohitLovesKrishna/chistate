{
  "name": "chistate",
  "version": "0.0.3",
  "author": "Rohit Ambawata",
  "license": "MIT",
  "description": "Reactive state. No hooks. No boilerplate.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react"
  },
  "keywords": [
    "state",
    "react",
    "signals",
    "zustand"
  ],
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@types/react": "^18",
    "react": ">=18"
  },
  "type": "commonjs"
}
